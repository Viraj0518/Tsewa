{
  "expo": {
    "name": "Tsewa",
    "slug": "tsewa",
    "version": "1.0.0",
    "scheme": "tsewa",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tsewa.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Tsewa needs camera access so you can take profile photos.",
        "NSPhotoLibraryUsageDescription": "Tsewa needs photo library access so you can choose profile photos.",
        "NSLocationWhenInUseUsageDescription": "Tsewa uses your approximate location to show you nearby matches.",
        "NSUserTrackingUsageDescription": "This data will be used to improve your match recommendations."
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": []
      }
    },
    "android": {
      "package": "com.tsewa.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tsewa needs photo library access so you can choose profile photos.",
          "cameraPermission": "Tsewa needs camera access so you can take profile photos."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "EAS_PROJECT_ID_HERE"
      }
    },
    "owner": "tsewa",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/EAS_PROJECT_ID_HERE"
    },
    "privacyPolicyUrl": "https://tsewa.app/privacy"
  }
}
