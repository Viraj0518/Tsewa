{
  "name": "@tsewa/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:auth": "vitest run src/__tests__/auth.test.ts",
    "test:profile": "vitest run src/__tests__/profile-discovery.test.ts",
    "test:swipe": "vitest run src/__tests__/swipe-matching.test.ts",
    "test:waitlist": "vitest run src/__tests__/waitlist-invite.test.ts",
    "test:feed": "vitest run src/__tests__/feed-events.test.ts",
    "test:rooms": "vitest run src/__tests__/rooms.test.ts",
    "test:ui": "vitest run --config vitest.config.e2e.ts",
    "test:pw": "npx playwright test --config playwright.config.ts",
    "test:pw:headed": "npx playwright test --config playwright.config.ts --headed"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.8.0",
    "uuid": "^11.0.0",
    "zod": "^3.24.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "playwright": "^1.59.1",
    "prisma": "^6.5.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.4"
  }
}
